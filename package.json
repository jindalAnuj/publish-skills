{
  "name": "publish-skills",
  "version": "1.2.0",
  "description": "A CLI tool that publishes AI agent skills to Git repositories via Pull/Merge Requests.",
  "main": "dist/cli/index.js",
  "bin": {
    "publish-skills": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "cli",
    "git",
    "publish",
    "skills",
    "ai",
    "agent",
    "github",
    "gitlab",
    "bitbucket",
    "claude",
    "claude-code",
    "cursor",
    "gemini",
    "gemini-cli",
    "copilot",
    "codex",
    "windsurf",
    "mcp",
    "llm",
    "ai-coding",
    "ai-skills",
    "agent-skills",
    "agentic",
    "devtools",
    "vercel-labs",
    "openclaw",
    "clawhub",
    "skill-publishing",
    "pull-request",
    "npx-skills"
  ],
  "author": "Anuj Jindal",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "homepage": "https://jindalanuj.github.io/publish-skills",
  "repository": {
    "type": "git",
    "url": "https://github.com/jindalAnuj/publish-skills"
  },
  "dependencies": {
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/auth-oauth-device": "^8.0.3",
    "@octokit/rest": "^22.0.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.0",
    "@types/yargs": "^17.0.35",
    "axios": "^1.13.6",
    "bitbucket": "^2.12.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "inquirer": "^13.3.2",
    "json-schema": "^0.4.0",
    "keytar": "^7.9.0",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6"
  }
}